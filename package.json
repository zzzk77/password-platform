{
  "name": "password-attack-defense-platform",
  "version": "1.0.0",
  "description": "密码虚拟攻防平台 - 双前端系统",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev:home": "vite --config vite.home.config.js",
    "dev:attack": "vite --config vite.attack.config.js",
    "dev:defense": "vite --config vite.defense.config.js",
    "build:attack": "vite build --config vite.attack.config.js",
    "build:defense": "vite build --config vite.defense.config.js",
    "preview:attack": "vite preview --config vite.attack.config.js",
    "preview:defense": "vite preview --config vite.defense.config.js",
    "start:electron": "cross-env ELECTRON_DEV=1 electron .",
    "dev:desktop": "npm-run-all --parallel dev:attack dev:defense start:electron",
    "build:desktop": "npm run build:attack && npm run build:defense && electron-builder"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "axios": "^1.13.2",
    "cors": "^2.8.6",
    "echarts": "^5.4.3",
    "element-plus": "^2.4.4",
    "express": "^5.2.1",
    "pinia": "^2.1.7",
    "vite": "^5.4.21",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "npm-run-all": "^4.1.5",
    "sass": "^1.69.5"
  },
  "build": {
    "appId": "com.padp.desktop",
    "productName": "密码虚拟攻防平台",
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
